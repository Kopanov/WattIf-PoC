# Copy to .env (gitignored) and fill as needed. The PoC runs with NO keys by default.

# --- LLM provider ---------------------------------------------------------
# "local" = Ollama (default, no key, runs offline). "anthropic" = server-side only.
LLM_PROVIDER=local
OLLAMA_MODEL=llama3.1
OLLAMA_HOST=http://localhost:11434
# Optional, server-side only on the hosted demo — never commit a real key.
ANTHROPIC_API_KEY=

# --- Data ------------------------------------------------------------------
# ENTSO-E day-ahead prices: free token by email (transparency@entsoe.eu).
# The demo falls back to a committed cached price vector, so this is optional.
ENTSOE_API_TOKEN=

# --- Demo theming (northern France / Hauts-de-France ~ Amiens; SICAE pilot region) ---
WHATIF_LAT=49.894
WHATIF_LON=2.296
WHATIF_TZ=Europe/Paris
WHATIF_BIDDING_ZONE=FR
WHATIF_CURRENCY=EUR

# Use committed cached data instead of live API calls (keeps the public demo key-free).
WHATIF_USE_CACHE=1
